---
import PageLayout from "@/layouts/PageLayout.astro";

const pageTitle = "404: Not Found";
const pageDescription = "The CSS is fine, but the page is gone.";
---

<PageLayout title={pageTitle} description={pageDescription}>
	<div class="container text-center" style="--container-size: 72ch;">
		<section aria-labelledby="error-title">
			<h1 id="error-title" class="glitch" data-text="404">404</h1>
			<p class="lead">{pageDescription}</p>
			<p class="text-muted">The page you're looking for doesn't exist or has been moved.</p>
			<p class="cta">
				<a href="/" class="btn --primary">Back to Home</a>
			</p>
		</section>
	</div>
</PageLayout>

<style>
	h1 {
		font-size: clamp(5rem, 15vw, 10rem);
		line-height: 1;
	}

	.glitch {
		position: relative;
		display: inline-block;

		&::before,
		&::after {
			content: attr(data-text);
			position: absolute;
			top: 0;
			left: 0;
			width: 100%;
			height: 100%;
			opacity: 0.8;
		}

		&::before {
			left: 2px;
			text-shadow: -2px 0 #ff00c1;
			clip: rect(44px, 450px, 56px, 0);

			@media (prefers-reduced-motion: no-preference) {
				animation: glitch-anim 5s infinite linear alternate-reverse;
			}
		}

		&::after {
			left: -2px;
			text-shadow:
				-2px 0 #00fff9,
				2px 2px #ff00c1;

			@media (prefers-reduced-motion: no-preference) {
				animation: glitch-anim2 1s infinite linear alternate-reverse;
			}
		}
	}

	@keyframes glitch-anim {
		0% {
			clip: rect(31px, 9999px, 94px, 0);
		}
		20% {
			clip: rect(62px, 9999px, 42px, 0);
		}
		40% {
			clip: rect(16px, 9999px, 78px, 0);
		}
		60% {
			clip: rect(1px, 9999px, 13px, 0);
		}
		80% {
			clip: rect(53px, 9999px, 86px, 0);
		}
		100% {
			clip: rect(91px, 9999px, 98px, 0);
		}
	}

	@keyframes glitch-anim2 {
		0% {
			clip: rect(65px, 9999px, 100px, 0);
		}
		20% {
			clip: rect(30px, 9999px, 100px, 0);
		}
		40% {
			clip: rect(15px, 9999px, 100px, 0);
		}
		60% {
			clip: rect(40px, 9999px, 100px, 0);
		}
		80% {
			clip: rect(80px, 9999px, 100px, 0);
		}
		100% {
			clip: rect(10px, 9999px, 100px, 0);
		}
	}

	.cta {
		margin-block-start: var(--size-12);
	}
</style>
