---
import PageLayout from "@/layouts/PageLayout.astro";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import { projects } from "@/projects";
import { SOCIALS } from "@/consts";
import Avatar from "@/components/Avatar.astro";
import PostCard from "@/components/PostCard.astro";
import Socials from "@/components/Socials.astro";

const posts = (await getCollection("blog"))
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
    .slice(0, 3);
---

<PageLayout>
    <div class="page-layout container">
        <section
            aria-labelledby="intro"
            class="flow-root"
            style={{ "--my": "2rem" }}
        >
            <Avatar
                class="float-end"
                style={{
                    "--my": "0 1rem",
                    "--mx": "1rem 0",
                }}
            />
            <h1 id="intro" class="lead">
                Hi, I am Sean van Zuidam also known on the web as @GrimLink.
            </h1>
            <p class="lead font-normal">
                I am a Frontend Developer from Zwolle, The Netherlands. Gamer,
                Anime watcher and fan of METAL, Rock and Chiptune music 🤘 I am
                also the creator of Fylgja CSS.
            </p>
            <hr />
            <p><strong>You can also find me on:</strong></p>
            <Socials data={SOCIALS} />
        </section>

        <section aria-labelledby="recent-posts">
            <h2 id="recent-posts">Recent Posts</h2>
            <ul role="list" class="flow">
                {
                    posts.map((post) => (
                        <li>
                            <PostCard {...post} />
                        </li>
                    ))
                }
            </ul>
            <p class="text-center">
                <a href="/blog" class="btn --primary"
                    >Read More Post from my Feed</a
                >
            </p>
        </section>

        <section aria-labelledby="projects">
            <h2 id="projects">Projects I Work on</h2>
            <ul role="list" class="flow divide-y">
                {projects.map((project) => <li>{JSON.stringify(project)}</li>)}
            </ul>
        </section>
    </div>
</PageLayout>

<style>
    .page-layout {
        @media (width >= 128ch) {
            display: grid;
            grid-template-columns: 34ch 1fr;
            gap: var(--size-12);

            > :first-child {
                grid-row: span 2;
            }
        }
    }
</style>
