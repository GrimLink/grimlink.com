---
import PageLayout from "@/layouts/PageLayout.astro";
import { getCollection } from "astro:content";
import PostCard from "@/components/PostCard.astro";
import BlogSidebar from "@/components/BlogSidebar.astro";
import BlogImg from "@/assets/blog.webp";

const posts = (await getCollection("blog")).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const pageTitle = "My Feed";
const pageDescription = "All my Blog and Social Posts in one handy page.";
---

<PageLayout
	title={pageTitle}
	description={pageDescription}
	image={BlogImg}
	breadcrumbs={[
		{ name: "Home", item: "/" },
		{ name: "Blog", item: "/blog/" },
	]}
>
	<div class="container">
		<h1>{pageTitle}</h1>
		<p>{pageDescription}</p>
		<div class="page-layout">
			<ul role="list" class="post-list flow">
				{
					posts.map((post) => (
						<li>
							<PostCard {...post} />
						</li>
					))
				}
			</ul>
			<BlogSidebar />
		</div>
	</div>
</PageLayout>

<style>
	.page-layout {
		@media (width >= 128ch) {
			display: grid;
			grid-template-columns: 1fr 34ch;
			gap: var(--size-12);
		}
	}

	.post-list {
		--flow: 1.5em;
	}
</style>
