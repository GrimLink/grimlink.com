---
import PageLayout from "@/layouts/PageLayout.astro";
import { getCollection } from "astro:content";
import PostCard from "@/components/PostCard.astro";
import BlogSidebar from "@/components/BlogSidebar.astro";
import BlogImg from "@/assets/blog.webp";

const currentYear = new Date().getFullYear();
const allPosts = await getCollection("blog");
const posts = allPosts
	.filter((post) => post.data.pubDate.getFullYear() === currentYear)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const prevYear = allPosts.some((post) => post.data.pubDate.getFullYear() === currentYear - 1)
	? currentYear - 1
	: null;

const pageTitle = "My Feed";
const pageDescription = "All my Blog and Social Posts in one handy page.";
---

<PageLayout
	title={pageTitle}
	description={pageDescription}
	image={BlogImg}
	breadcrumbs={[
		{ name: "Home", item: "/" },
		{ name: "Blog", item: "/blog/" },
	]}
>
	<div class="container">
		<h1>{pageTitle}</h1>
		<p>{pageDescription}</p>
		<div class="page-layout">
			<div>
				<ul role="list" class="post-list flow">
					{
						posts.map((post, i) => (
							<li>
								<PostCard
									{...post}
									class="reveal"
									loading={i === 0 ? "eager" : "lazy"}
								/>
							</li>
						))
					}
				</ul>
				<nav
					class="flex-col gap"
					aria-label="Year navigation"
					style={{ "--sm_flex-dir": "row", "--my": "var(--size-8) 0" }}
				>
					<a href="#main" class="btn flex-auto">Back to Top</a>
					{
						prevYear ? (
							<a href={`/blog/${prevYear}/`} class="btn flex-auto">
								Go to {prevYear}
								<span aria-hidden="true">→</span>
							</a>
						) : (
							<span />
						)
					}
				</nav>
			</div>
			<BlogSidebar />
		</div>
	</div>
</PageLayout>

<style>
	.page-layout {
		@media (width >= 128ch) {
			display: grid;
			grid-template-columns: 1fr 34ch;
			gap: var(--size-12);
		}
	}

	.post-list {
		--flow: 1.5em;
	}
</style>
