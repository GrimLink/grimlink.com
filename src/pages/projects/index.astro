---
import PageLayout from "@/layouts/PageLayout.astro";
import AboutImg from "@/assets/about.webp";
import dataJson from "./data.json";

const sort = (list: { status?: string }[]) =>
	list.sort((a, b) => (a.status === "inactive" ? 1 : 0) - (b.status === "inactive" ? 1 : 0));

const personal = sort(dataJson.personal);
const siteation = sort(dataJson.siteation);
const fylgja = sort(dataJson.fylgja);

const pageTitle = "Projects";
const pageDescription =
	"An overview of the open-source projects and tools I maintain, both personal and as part of Fylgja CSS.";
---

<PageLayout
	title={pageTitle}
	description={pageDescription}
	image={AboutImg}
	breadcrumbs={[
		{ name: "Home", item: "/" },
		{ name: "Projects", item: "/projects/" },
	]}
	class="container"
>
	<h1>{pageTitle}</h1>
	<p>{pageDescription}</p>

	<section aria-labelledby="personal-projects">
		<h2 id="personal-projects">Personal</h2>
		<dl class="project-list">
			{
				personal.map((project) => (
					<>
						<dt>
							{project.status && (
								<span class:list={["status", project.status]}>
									{project.status}
								</span>
							)}
							<a
								href={project.url}
								target="_blank"
								rel="noopener noreferrer"
								class="hover-underline"
							>
								{project.name}
							</a>
						</dt>
						{project.description && <dd>{project.description}</dd>}
					</>
				))
			}
		</dl>
	</section>

	<section aria-labelledby="fylgja-projects">
		<h2 id="fylgja-projects">Fylgja CSS</h2>
		<p>
			Projects under the <a
				href="https://fylgja.dev/"
				target="_blank"
				rel="noopener noreferrer">Fylgja CSS</a
			> organisation.
		</p>
		<dl class="project-list">
			{
				fylgja.map((project) => (
					<>
						<dt>
							{project.status && (
								<span class:list={["status", project.status]}>
									{project.status}
								</span>
							)}
							<a
								href={project.url}
								target="_blank"
								rel="noopener noreferrer"
								class="hover-underline"
							>
								{project.name}
							</a>
						</dt>
						{project.description && <dd>{project.description}</dd>}
					</>
				))
			}
		</dl>
	</section>

	<section aria-labelledby="siteation-projects">
		<h2 id="siteation-projects">Siteation</h2>
		<p>
			StoreInfo modules for Magento 2, published under the <a
				href="https://github.com/Siteation"
				target="_blank"
				rel="noopener noreferrer">Siteation</a
			> organisation.
		</p>
		<dl class="project-list">
			{
				siteation.map((project) => (
					<>
						<dt>
							{project.status && (
								<span class:list={["status", project.status]}>
									{project.status}
								</span>
							)}
							<a
								href={project.url}
								target="_blank"
								rel="noopener noreferrer"
								class="hover-underline"
							>
								{project.name}
							</a>
						</dt>
						{project.description && <dd>{project.description}</dd>}
					</>
				))
			}
		</dl>
	</section>
</PageLayout>

<style>
	section {
		margin-block-start: var(--size-8);
	}

	.project-list {
		--list-flow: 0;
		display: grid;
		grid-template-columns: 1fr;
		margin-block-start: var(--size-4);

		dt,
		dd {
			padding-block: var(--size-2);
		}

		dt {
			padding-inline-end: var(--size-6);
			padding-block-end: 0;
		}

		dd {
			color: var(--color-muted);
			border-block-end: 1px solid oklch(from var(--root-fg) l c h / 10%);
		}

		@media (width >= 640px) {
			grid-template-columns: auto 1fr;

			dt {
				border-block-end: 1px solid oklch(from var(--root-fg) l c h / 10%);
				padding-block-end: var(--size-2);
			}
		}
	}

	.status {
		display: inline-flex;
		font-size: 0.75em;
		padding-inline: 0.5em;
		padding-block: 0.15em;
		border-width: 1px;
		border-radius: 1em;
		vertical-align: middle;
		margin-inline-end: 0.5em;

		&.active {
			color: light-dark(var(--brand), color-mix(in oklch, var(--brand) 60%, var(--root-fg)));
		}

		&.inactive {
			color: var(--color-muted);
		}
	}
</style>
