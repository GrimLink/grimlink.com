---
import PageLayout from "@/layouts/PageLayout.astro";
import Avatar from "@/components/Avatar.astro";

const pageTitle = "About Me";
const pageDescription =
    "Learn more about Sean van Zuidam, Frontend Developer and creator of Fylgja CSS.";
---

<PageLayout title={pageTitle} description={pageDescription}>
    <div class="container" style="--container-size: 72ch; --my: var(--size-8)">
        <section
            class="flex gap align"
            style="--gap: var(--size-4) var(--size-8); --align-items: center;"
            aria-labelledby="intro"
        >
            <div class="flow">
                <h1 id="intro">Hi, I'm Sean.</h1>
                <p class="lead">
                    Frontend Developer at
                    <a href="https://hyva.io" target="_blank">Hyvä Themes</a>,
                    creator of
                    <a href="https://fylgja.dev" target="_blank">Fylgja CSS</a>,
                    and a firm believer in modular, performant web developement.
                </p>
            </div>
            <Avatar size={160} class="flex-none" />
        </section>

        <section aria-labelledby="what-im-doing-now">
            <h2 id="what-im-doing-now">What I'm doing now</h2>
            <div>
                <p>
                    Based in Zwollywood (Zwolle), The Netherlands, my
                    professional life currently revolves around the Magento
                    ecosystem, specifically making it faster and more enjoyable
                    to work with through
                    <strong>Hyvä Themes</strong>. As the "Frontend Wizard," I
                    help build the UI and themes that power modern e-commerce
                    experiences.
                </p>
                <p>
                    When I'm not deep in Magento templates, I'm working on <strong
                        >Fylgja CSS</strong
                    >. Fylgja CSS aims to solve many issues that CSS frameworks
                    have, by providing a modular library that lets developers
                    use only what they need.
                </p>
            </div>
        </section>

        <section aria-labelledby="my-professional-journey">
            <h2 id="my-professional-journey">My Professional Journey</h2>
            <div>
                <p>
                    My journey in the web started with a passion for systems
                    thinking and finding efficient ways to build interfaces.
                    Before joining Hyvä, I spent nearly a decade at other
                    e-commerce agencies, where I work on small and large-scale
                    e-commerce projects.
                </p>
                <p>
                    I've also been an active part of the community, helping out
                    at events like <strong>MageUnconference NL</strong> and contributing
                    to various open-source projects. For me, the web is at its best
                    when it's collaborative and open.
                </p>
            </div>
        </section>

        <section aria-labelledby="philosophy-tools">
            <h2 id="philosophy-tools">Philosophy & Tools</h2>
            <div>
                <p>
                    I lean towards <strong>minimalism</strong> in code. I believe
                    in the "pay only for what you use" architecture. If a project
                    doesn't need a massive framework, don't use one.
                </p>
                <p>
                    I use a Macbook with the Zed Editor. For the rest of the
                    tools I use, you can find it on
                    <a href="https://github.com/grimlink/dotfiles"
                        >my github, under my dotfiles</a
                    >.
                </p>
            </div>
        </section>

        <section aria-labelledby="beyond-the-code">
            <h2 id="beyond-the-code">Beyond the Code</h2>
            <div>
                <p>
                    Life isn't just about semi-colons and CSS. When I step away
                    from the keyboard, you'll likely find me:
                </p>
                <ul role="list">
                    <li>
                        🤘 <strong>Listening to Music:</strong> Rock, Metal, and video
                        game soundtracks.
                    </li>
                    <li>
                        🎮 <strong>Gaming:</strong> From retro classics to modern
                        experiments.
                    </li>
                    <li>
                        📺 <strong>Anime:</strong> A long-time fan of the medium's
                        unique storytelling and a hugh fan of One Piece.
                    </li>
                    <li>
                        🪴 <strong>Planting:</strong> A passionate gardener who loves
                        to grow plants.
                    </li>
                </ul>
            </div>
        </section>
    </div>
</PageLayout>
