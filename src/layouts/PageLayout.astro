---
import "@/assets/main.css";
import type { ImageMetadata } from "astro";

import Head from "@fylgja/Head.astro";
import ServiceWorker from "@/components/ServiceWorker.astro";
import ThemeToggleJs from "@/components/ThemeToggle/script.astro";
import PageHeader from "@/components/PageHeader.astro";
import PageFooter from "@/components/PageFooter.astro";
import { SchemaMe, SchemaSite, SchemaBreadcrumbs } from "@/components/Schema";
import Speculation from "@fylgja/Speculation.astro";

import PlaceHolderImg from "@/assets/placeholder.webp";
import { author, siteTitle, siteDescription, themeColor, isProd, today } from "@/consts";

interface Props {
	title?: string;
	description?: string;
	image?: ImageMetadata;
	lang?: string;
	dir?: string;
	class?: string;
	style?:
		| {
				[key: string]: string;
		  }
		| string;
	breadcrumbs?: { name: string; item: string }[];
}

const {
	title = siteTitle,
	description = siteDescription,
	image = PlaceHolderImg,
	lang = "en",
	dir = "ltr",
	class: className = "",
	style,
	breadcrumbs,
} = Astro.props;
const rssUrl = new URL("rss.xml", Astro.site);
const dateHash = `?v=${today.getMonth() + 1}-${today.getFullYear()}`;
---

<html lang={lang} dir={dir} data-theme="auto">
	<Head
		siteName={siteTitle}
		title={title}
		description={description}
		publisher={author}
		image={image}
		themeColor={themeColor}
		sitemap="/sitemap-index.xml"
		manifest={`/manifest.webmanifest${dateHash}`}
		rss={rssUrl}
		fediverse="@GrimLink@mastodon.social"
	>
		<ThemeToggleJs />
		<Speculation />
		<slot name="head" />
		<SchemaSite />
		<SchemaMe />
		{breadcrumbs && <SchemaBreadcrumbs items={breadcrumbs} />}
		{isProd && <ServiceWorker />}
	</Head>
	<body>
		<PageHeader />
		<main id="main" class:list={className} style={style}>
			<slot />
		</main>
		<PageFooter />
	</body>
</html>
