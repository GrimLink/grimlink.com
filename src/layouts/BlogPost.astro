---
import "@/assets/main.css";
import type { CollectionEntry } from "astro:content";

import Head from "@fylgja/Head.astro";
import ServiceWorker from "@/components/ServiceWorker.astro";
import ThemeToggleJs from "@/components/ThemeToggle/script.astro";
import PageHeader from "@/components/PageHeader.astro";
import PageFooter from "@/components/PageFooter.astro";
import { SchemaMe, SchemaSite } from "@/components/Schema";
import Speculation from "@fylgja/Speculation.astro";
import FormattedDate from "@/components/FormattedDate.astro";
import PostNavigation from "@/components/PostNavigation.astro";
import OriginalSource from "@/components/OriginalSource.astro";
import Tags from "@/components/Tags.astro";
import ShareButton from "@fylgja/ShareButton.astro";

import FallbackImage1 from "@/assets/placeholder/blue.jpg";
import FallbackImage2 from "@/assets/placeholder/purple.jpg";
import FallbackImage3 from "@/assets/placeholder/red.jpg";
import FallbackImage4 from "@/assets/placeholder/yellow.jpg";
import { author, siteTitle, siteDescription, themeColor, isProd, today } from "@/consts";

type BlogProps = CollectionEntry<"blog">["data"];
interface Props extends BlogProps {
	lang?: string;
	dir?: string;
	class?: string;
	prev?: CollectionEntry<"blog"> | null;
	next?: CollectionEntry<"blog"> | null;
}

const {
	title = siteTitle,
	description = siteDescription,
	pubDate,
	updatedDate,
	image,
	tags = [],
	pubSource = "",
	lang = "en",
	dir = "ltr",
	class: className = "",
	prev,
	next,
} = Astro.props;
const fallbackImages = [FallbackImage1, FallbackImage2, FallbackImage3, FallbackImage4];
const fallbackImage = fallbackImages[pubDate.getTime() % fallbackImages.length];
const rssUrl = new URL("feed.xml", Astro.site);
const dateHash = `?v=${today.getMonth() + 1}-${today.getFullYear()}`;
---

<html lang={lang} dir={dir} data-theme="auto">
	<Head
		siteName={siteTitle}
		title={title}
		description={description}
		publisher={author}
		image={image || fallbackImage}
		themeColor={themeColor}
		sitemap="/sitemap-index.xml"
		manifest={`/manifest.webmanifest${dateHash}`}
		rss={rssUrl}
		fediverse="@GrimLink@mastodon.social"
	>
		<ThemeToggleJs />
		<Speculation />
		<slot name="head" />
		<SchemaSite />
		<SchemaMe />
		{isProd && <ServiceWorker />}
	</Head>
	<body>
		<PageHeader />
		<main class:list={["container", className]} style="--container-size: 68ch">
			<article>
				<h1>{title}</h1>
				<div class="post-meta">
					<span>
						<FormattedDate date={pubDate} />
						{
							updatedDate && (
								<span class="last-updated-on">
									Last updated on <FormattedDate date={updatedDate} />
								</span>
							)
						}
						{pubSource && <OriginalSource source={pubSource} />}
					</span>
				</div>
				<slot />
			</article>
			<div class="flex gap align" style={{ "--my": "var(--size-6) 0" }}>
				<Tags tags={tags} />
				<ShareButton url={new URL(Astro.url)} title={title} class="btn --primary" />
			</div>
			<hr />
			<PostNavigation prev={prev} next={next} />
		</main>
		<PageFooter />
	</body>
</html>

<style>
	.post-meta {
		font-style: italic;
		color: var(--color-muted);
	}
</style>
