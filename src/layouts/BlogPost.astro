---
import "@/assets/main.css";
import type { CollectionEntry } from "astro:content";

import Head from "@fylgja/Head.astro";
import ServiceWorker from "@/components/ServiceWorker.astro";
import ThemeToggleJs from "@/components/ThemeToggle/script.astro";
import PageHeader from "@/components/PageHeader.astro";
import PageFooter from "@/components/PageFooter.astro";
import { SchemaMe, SchemaSite, SchemaBlogPosting, SchemaBreadcrumbs } from "@/components/Schema";
import Speculation from "@fylgja/Speculation.astro";
import FormattedDate from "@/components/FormattedDate.astro";
import PostNavigation from "@/components/PostNavigation.astro";
import DiscussionLinks from "@/components/DiscussionLinks.astro";
import Tags from "@/components/Tags.astro";
import ShareButton from "@fylgja/ShareButton.astro";
import ShareBluesky from "@fylgja/ShareBluesky.astro";

import PlaceHolderImg from "@/assets/placeholder.webp";
import { author, siteTitle, siteDescription, themeColor, isProd, today } from "@/consts";

type BlogProps = CollectionEntry<"blog">["data"];
interface Props extends BlogProps {
	id?: string;
	lang?: string;
	dir?: string;
	class?: string;
	prev?: CollectionEntry<"blog"> | null;
	next?: CollectionEntry<"blog"> | null;
}

const {
	title = siteTitle,
	description = siteDescription,
	pubDate,
	updatedDate,
	image,
	tags = [],
	crossPosts,
	id,
	lang = "en",
	dir = "ltr",
	class: className = "",
	prev,
	next,
} = Astro.props;
const rssUrl = new URL("rss.xml", Astro.site);
const dateHash = `?v=${today.getMonth() + 1}-${today.getFullYear()}`;
const postId = id ? `post-${id.replace(/^\/|\/$/g, "").replaceAll("/", "-")}` : undefined;
const hasTags = tags && tags.length > 0;
---

<html lang={lang} dir={dir} data-theme="auto">
	<Head
		siteName={siteTitle}
		title={title}
		description={description}
		publisher={author}
		image={image || PlaceHolderImg}
		themeColor={themeColor}
		sitemap="/sitemap-index.xml"
		manifest={`/manifest.webmanifest${dateHash}`}
		rss={rssUrl}
		fediverse="@GrimLink@mastodon.social"
	>
		<ThemeToggleJs />
		<Speculation />
		<slot name="head" />
		<SchemaSite />
		<SchemaMe />
		<SchemaBlogPosting
			title={title}
			description={description}
			pubDate={pubDate}
			updatedDate={updatedDate}
			image={image?.src}
			tags={tags}
		/>
		<SchemaBreadcrumbs
			items={[
				{ name: "Home", item: "/" },
				{ name: "Blog", item: "/blog" },
				{ name: title, item: Astro.url.pathname },
			]}
		/>
		{isProd && <ServiceWorker />}
	</Head>
	<body>
		<PageHeader />
		<main id="main" class:list={["container", className]} style="--container-size: 68ch">
			<article>
				<h1 class="post-heading">{title}</h1>
				<div class="post-meta">
					<FormattedDate date={pubDate} />
					{
						updatedDate && (
							<>
								<span> ∙ </span>
								<span class="last-updated-on">
									Last updated on <FormattedDate date={updatedDate} />
								</span>
							</>
						)
					}
					{hasTags && <span> ∙ </span>}
					{hasTags && <Tags tags={tags} />}
				</div>
				<slot />
			</article>
			<div class="flex gap align" style={{ "--my": "var(--size-6) 0" }}>
				<div>
					{crossPosts && <DiscussionLinks sources={crossPosts} />}
				</div>
				<div class="inline-flex gap-sm">
					<ShareBluesky url={new URL(Astro.url)} class="btn --primary" />
					<ShareButton url={new URL(Astro.url)} title={title} class="btn --primary" />
				</div>
			</div>
			<hr />
			<PostNavigation prev={prev} next={next} />
		</main>
		<PageFooter />
	</body>
</html>

<style
	define:vars={{
		postId,
		postIdHeading: postId ? `${postId}-heading` : undefined,
		postIdMeta: postId ? `${postId}-Meta` : undefined,
	}}
>
	.post-meta {
		font-style: italic;
		color: var(--color-muted);
	}

	@media (prefers-reduced-motion: no-preference) {
		.post-heading {
			view-transition-name: var(--postIdHeading);
		}

		.post-meta {
			view-transition-name: var(--postIdMeta);
		}
	}
</style>
