---
import type { HTMLAttributes } from "astro/types";

type TagProps = HTMLAttributes<"div" | "article">;
interface Props extends TagProps {
	tag?: "div" | "article" | "li";
}

const { tag = "div", class: className, ...props } = Astro.props;
const Tag = tag;
---

<Tag class:list={["card", className]} {...props}>
	<slot />
</Tag>

<style>
	@media (prefers-reduced-motion: no-preference) {
		.card:has(.stretched-link):hover {
			scale: 1.03;
		}
	}

	.card:has(iframe:only-child) {
		--card-py: 0;
		--card-px: 0;
	}
</style>
