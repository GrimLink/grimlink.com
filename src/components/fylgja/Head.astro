---
import type { ImageMetadata } from "astro";

interface Props {
    title: string;
    description: string;
    image?: ImageMetadata;
    canonical?: URL;
    pageType?: "website" | "article";
    siteName: string;
    favicon?: string;
    icon?: string;
    appleIcon?: string;
    manifest?: string;
    sitemap?: string;
    rss?: URL;
    themeColor?: string;
    themeColorDark?: string;
    separator?: string;
}

const {
    siteName,
    title,
    description,
    image,
    canonical = new URL(Astro.url.pathname, Astro.site),
    favicon = "/favicon.ico",
    icon = "/favicon.svg",
    appleIcon = "/apple-touch-icon.png",
    manifest,
    sitemap,
    rss,
    themeColor = "#fff",
    themeColorDark,
    pageType = "website",
    separator = " - ",
} = Astro.props;
---

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>
        {title === siteName ? siteName : `${title}${separator}${siteName}`}
    </title>
    <link rel="canonical" href={canonical} />

    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="apple-mobile-web-app-title" content={title} />

    {favicon && <link rel="icon" href={favicon} sizes="32x32" />}
    {icon && <link rel="icon" href={icon} type="image/svg+xml" />}
    {appleIcon && <link rel="apple-touch-icon" href={appleIcon} />}

    {manifest && <link rel="manifest" href={manifest} />}

    {sitemap && <link rel="sitemap" href={sitemap} />}

    {
        rss && (
            <link
                rel="alternate"
                type="application/rss+xml"
                title={siteName}
                href={rss}
            />
        )
    }

    {
        themeColorDark && (
            <meta
                name="theme-color"
                content={themeColorDark}
                media="(prefers-color-scheme: dark)"
            />
        )
    }
    {themeColor && <meta name="theme-color" content={themeColor} />}

    <slot name="socials">
        <meta property="og:type" content={pageType} />
        <meta property="og:url" content={Astro.url} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        {
            image && (
                <meta
                    property="og:image"
                    content={new URL(image.src, Astro.url)}
                />
            )
        }
    </slot>

    <meta name="generator" content={Astro.generator} />
    <meta name="generator" content="Fylgja CSS" />

    <slot />
</head>
