---
import Schema from "@fylgja/Schema.astro";
import { getImage } from "astro:assets";
import avatarSrc from "@/assets/avatar.jpg";
import { author, authorAbout, authorTitle, socials } from "@/consts";

const avatar = await getImage({ src: avatarSrc, format: "webp" });
const avatarUrl = new URL(avatar.src, Astro.site).href;
---

<Schema
	data={{
		"@context": "https://schema.org",
		"@type": "Person",
		name: author,
		url: new URL(Astro.url.pathname, Astro.site),
		image: avatarUrl,
		sameAs: Object.values(socials),
		jobTitle: authorTitle,
		description: authorAbout,
		brand: {
			"@type": "Brand",
			name: "Fylgja CSS",
			url: "https://fylgja.dev/",
		},
		knowsAbout: [
			"CSS",
			"Web Development",
			"JavaScript",
			"HTML",
			"Web Design",
			"UX",
			"Accessibility",
			"Performance",
			"Design Systems",
			"Web Standards",
			"E-Commerce",
		],
	}}
/>
