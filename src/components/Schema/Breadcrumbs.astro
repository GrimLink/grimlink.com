---
import Schema from "@fylgja/Schema.astro";

interface Props {
	items: {
		name: string;
		item: string;
	}[];
}

const { items } = Astro.props;

const breadcrumbList = {
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	itemListElement: items.map((item, index) => ({
		"@type": "ListItem",
		position: index + 1,
		name: item.name,
		item: new URL(item.item, Astro.site).href,
	})),
};
---

<Schema data={breadcrumbList} />
