---
import { author, today } from "@/consts";
import { footerMenu } from "@/menus";
---

<footer class="page-footer container">
	<nav>
		<ul class="inline-flex gap">
			{
				footerMenu.map((item) => (
					<li>
						<a
							href={item.url}
							aria-current={item.url === Astro.url.pathname ? "page" : undefined}
						>
							{item.label}
						</a>
					</li>
				))
			}
		</ul>
	</nav>
	<small class="block">
		© {today.getFullYear()}
		{author}.
	</small>
</footer>
<style>
	footer {
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		align-items: center;
		gap: var(--size-4);
		margin-block-start: var(--size-16);
		padding-block: var(--size-8);
		border-block-start: 1px solid oklch(from var(--root-fg) l c h / 10%);

		@media (width >= 768px) {
			flex-direction: row;

			small {
				order: -1;
			}
		}
	}
</style>
